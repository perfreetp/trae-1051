{
  "name": "container-yard-management",
  "version": "1.0.0",
  "description": "港口集装箱堆场管理系统",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "pinia": "^2.1.7",
    "element-plus": "^2.4.4",
    "@element-plus/icons-vue": "^2.3.1",
    "better-sqlite3": "^9.2.2",
    "dayjs": "^1.11.10",
    "echarts": "^5.4.3",
    "vue-echarts": "^6.6.1",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vue-tsc": "^1.8.25",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "@types/node": "^20.10.5",
    "@types/better-sqlite3": "^7.6.8",
    "@types/lodash": "^4.14.202"
  },
  "build": {
    "appId": "com.containeryard.management",
    "productName": "集装箱堆场管理系统",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  }
}
